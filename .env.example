# Copy this file to ".env" and fill in real values there.
# ".env" is gitignored; THIS template is safe to commit.

# ===== Profile A: Ollama (local dev — free, unlimited, private) =====
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
SIDEKICK_TRIAGE_MODEL=qwen3:1.7b
SIDEKICK_ACT_MODEL=qwen3:8b
SIDEKICK_TICK_SECONDS=60

# ===== Profile B: Gemini free tier (for the deployed live link, later) =====
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your_gemini_key_here
# SIDEKICK_TRIAGE_MODEL=gemini-2.5-flash-lite
# SIDEKICK_ACT_MODEL=gemini-2.5-flash
# SIDEKICK_TICK_SECONDS=600

SIDEKICK_DATA_DIR=./data